# Copy this file to .env and fill in your own values.

# Create React App config
SKIP_PREFLIGHT_CHECK=true
NODE_OPTIONS=--openssl-legacy-provider

# PostgreSQL connection
PGUSER=postgres
PGHOST=localhost
PGDATABASE=mongke
PGPASSWORD=your_postgres_password
PGPORT=5432

# Express session secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
SESSION_SECRET=replace_with_a_long_random_string

# Server
PORT=5001

# Clarifai (computer vision API for handwritten character recognition)
# Sign up at https://www.clarifai.com to obtain a key.
CLARIFAI_PAT=your_clarifai_personal_access_token
CLARIFAI_USER_ID=your_clarifai_user_id
CLARIFAI_APP_ID=your_clarifai_app_id
CLARIFAI_MODEL_ID=your_clarifai_model_id

# Forwarded to the React build so the frontend can call the API.
REACT_APP_API_URL=http://localhost:5001
REACT_APP_CLARIFAI_PAT=your_clarifai_personal_access_token
REACT_APP_CLARIFAI_USER_ID=your_clarifai_user_id
REACT_APP_CLARIFAI_APP_ID=your_clarifai_app_id
REACT_APP_CLARIFAI_MODEL_ID=your_clarifai_model_id
